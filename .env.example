# ===========================================
# Polymarket Configuration
# ===========================================
# Your Polymarket API key (from CLOB API)
POLYMARKET_API_KEY=
# Your private key for signing transactions (NO 0x prefix)
POLYMARKET_PRIVATE_KEY=
# API endpoint (default: production)
POLYMARKET_API_URL=https://clob.polymarket.com

# ===========================================
# Binance Configuration (price feed)
# ===========================================
BINANCE_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@trade

# ===========================================
# Trading Configuration
# ===========================================
# Maximum position size in USDC per trade
MAX_POSITION_SIZE=10.0
# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=3
# Minimum edge required to enter a trade (0.0 - 1.0)
MIN_EDGE_THRESHOLD=0.02
# Stop loss percentage (0.0 - 1.0)
STOP_LOSS_PCT=0.15

# ===========================================
# Strategy Configuration
# ===========================================
# Lookback window in seconds for momentum calculation
MOMENTUM_LOOKBACK_SECS=120
# RSI period (number of ticks)
RSI_PERIOD=14
# Bollinger Band standard deviations
BB_STD_DEV=2.0

# ===========================================
# Database (auto-set by Heroku Postgres addon)
# ===========================================
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
